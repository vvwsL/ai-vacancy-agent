# Скопируй этот файл в .env и впиши ключ нужного провайдера.
# Если ни одного ключа нет — агент автоматически уходит в dry-run (rule-based),
# и всё равно собирает отчёт.

# Достаточно ОДНОГО ключа любого провайдера ниже (все OpenAI-совместимы, бесплатны,
# без карты). auto-режим выберет первый, для которого есть ключ (в порядке ниже).

# Gemini (Google AI Studio): https://aistudio.google.com/apikey  — 1500 req/день.
GEMINI_API_KEY=

# Groq: https://console.groq.com/keys  — ~1000 req/день. Ключ вида gsk_...
GROQ_API_KEY=

# OpenRouter: https://openrouter.ai/keys  — ~200 req/день, вход через Google. Ключ sk-or-...
OPENROUTER_API_KEY=

# Cerebras: https://cloud.cerebras.ai  — 1M токенов/день. Ключ csk-...
CEREBRAS_API_KEY=
